# ============================================
# Homework Helper 环境变量配置
# ============================================

# 数据库配置 (Turso / LibSQL)
# 本地开发: file:data.sqlite
# Vercel 部署: 使用 Turso 云数据库
#   1. 注册 https://turso.tech (免费额度足够)
#   2. 创建数据库: turso db create homework-helper
#   3. 获取 URL: turso db show homework-helper --url
#   4. 获取 Token: turso db tokens create homework-helper
DATABASE_URL=file:data.sqlite
DATABASE_AUTH_TOKEN=

# ============================================
# 以下 AI 配置也可以通过网页设置页面配置
# 环境变量仅作为备用说明
# ============================================
# AI API Keys 在网页 /config 页面配置即可
